# Calliope.AI — env template (copia in .env, .env è gitignored)

# Discord user token (NON bot token)
# Retrieval: Discord web client → F12 DevTools → Network tab → click any request →
# Headers → "authorization" header value (string lunga, NO virgolette, NO prefisso "Bearer")
# WARNING: NON committare mai .env. Token = accesso completo al tuo account.
DISCORD_USER_TOKEN=

# Discord guild ID Kingdom of Yokai
# Retrieval: Discord Settings → Advanced → enable Developer Mode → right-click server icon → Copy Server ID
KOY_GUILD_ID=

# Channel ID character-sheets (per estrazione mirata schede char + threads)
# Right-click sul channel → Copy Channel ID
CHARACTER_SHEETS_CHANNEL_ID=

# Tupperbox token (opzionale, se vuoi automation API. Manual dashboard export comunque consigliato)
TUPPERBOX_TOKEN=
