# Quill of Calliope — privacy-aggressive gitignore
# Dati RP NON commitabili (sensibili + privacy + multi-player content)

# === LIVE2D DEV-MODELS license-restricted (MAI in git-history) ===
# Koko = licenza no-redistribute; Tingyun = fan-IP HoYoverse. Solo dev-reference
# locale, da sostituire con modello clean (Mao/Tororo) prima di open-source/deploy.
shared/live2d_mascot/models/koko/
shared/live2d_mascot/models/tingyun/

# Mao (shippable sample model): keep the human-readable config (model3/exp3/
# motion/physics JSON + README) in-repo, but EXCLUDE the heavy binaries — they
# exceed the 500 KB large-file guard. Restore them with scripts/fetch_mao_model.sh.
shared/live2d_mascot/models/mao/Mao.moc3
shared/live2d_mascot/models/mao/Mao.2048/

# === DATASETS (raw imports — NEVER commit) ===
datasets/
*.xls
*.xlsx
*.csv
*.discord-export.json
chatgpt-export*.json

# === CHROMADB (binary local index) ===
.chroma_calliope/
*.chroma/
chroma_data/

# === CHARACTERS (privato per default, sensitive PII NPC) ===
# Operator può whitelistare specifici char con git add -f <path>
characters/private/
characters/*.private.yaml

# === SCENES (running narrative state, NO commit) ===
scenes/*.md
!scenes/.gitkeep
!scenes/TEMPLATE.md

# === SESSIONS (operator workflow private) ===
sessions/
*.session.json
*.session.md

# === IMPORTS TEMP ===
/tmp/calliope_*
*.parsed.jsonl
*.draft.md

# === SECRETS ===
.env
.env.local
*.key
*.token
api_keys.yaml
discord_token*

# === PYTHON ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# === VENV ===
venv/
env/
.venv/
ENV/

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === OS ===
.DS_Store
Thumbs.db

# === LOG + CACHE ===
*.log
logs/
.cache/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# === SILLYTAVERN local instance (se decidiamo embed) ===
sillytavern/
node_modules/

# === EXTERNAL (third-party clones, NOT vendored) ===
external/

# === PLANNING (sprint tracking ongoing, gitignored) ===
.planning/

# === DOCS draft (review before commit) ===
docs/*.draft.md
docs/sessions/

# === TTS (audio output, large files) ===
*.wav
*.mp3
*.ogg
audio_output/
.chroma_calliope_dryrun/
.aider*
graphify-out/

# === Runtime data (local DB, ChromaDB shards) ===
data/*.db
data/chromadb/
data/discord_persona_config.db
data/lore_kb.json
data/backups/
db/
data/*.db-shm
data/*.db-wal

# === Live2D models (binaries — restore via scripts/fetch_mao_model.sh) ===
shared/live2d_mascot/models/mao/Mao.moc3
shared/live2d_mascot/models/mao/Mao.2048/
shared/live2d_mascot/models/koko/
shared/live2d_mascot/models/tingyun/
!.planning/CALLIOPE_GAP_REVIEW_2026-06-07.md
data/backups/
